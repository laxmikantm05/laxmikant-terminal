    }

    #details {
        height: 1fr;
        padding: 1 3;
        background: #0a0005;
        overflow-y: auto;
    }

    #statusbar {
        height: 1;
        background: #1a0008;
        color: #888888;
        padding: 0 2;
        content-align: left middle;
    }

    #controls-bar {
        height: 2;
        dock: bottom;
        background: #cc0022;
        color: #ffffff;
        text-style: bold;
        padding: 0 2;
        content-align: left middle;
        border-top: solid #ff0033;
    }

    Footer { display: none; }
"""

    BINDINGS = [
        Binding("r",      "scan",       "[R] Rescan"),
        Binding("d",      "disconnect", "[D] Disconnect"),
        Binding("f",      "forget",     "[F] Forget"),
        Binding("h",      "hotspot",    "[H] Hotspot"),
        Binding("k",      "known",      "[K] Known"),
        Binding("c",      "copy_ip",    "[C] Copy IP"),
        Binding("t",      "toggle",     "[T] Toggle"),
        Binding("q",      "quit",       "[Q] Quit"),
        Binding("escape", "quit",       "", show=False),
        Binding("enter",  "connect",    "[Enter] Connect"),
    ]

    _networks = []
    _ping     = None

    def compose(self):
        yield Static("", id="header")
        with Horizontal(id="body"):
            with Vertical(id="left-panel"):
                yield Label("  󰤨  NETWORKS", classes="panel-title", id="net-title")
                yield ListView(id="network-list")
            with Vertical(id="right-panel"):
                yield Label("  DETAILS", classes="panel-title")
                yield Static("", id="details")
        yield Static("", id="statusbar")
        yield Static("  [Enter] Connect   [D] Disconnect   [F] Forget   [H] Hotspot   [K] Known   [C] Copy IP   [T] Toggle   [R] Rescan   [Q] Quit", id="controls-bar")


    def on_mount(self):
        self._refresh_header()
        self._set_details(None)
        self.query_one("#network-list").focus()
        self.action_scan()
        self.set_interval(CFG["wifi"]["scan_interval"],   self.action_scan)
        self.set_interval(CFG["wifi"]["header_interval"], self._refresh_header)

    def _refresh_header(self):
        on  = wifi_enabled()
        ac  = active_connection()
        flg = "[green]WiFi ON[/green]" if on else "[red]WiFi OFF[/red]"
        t   = datetime.datetime.now().strftime("%H:%M:%S")
        hs  = hotspot_active()
        hs_str = "  [yellow]󰤱 hotspot active[/yellow]" if hs else ""
        if ac:
            ip_info = get_ip_info(ac.get("device", ""))
            ip      = ip_info.get("ip", "")
            conn    = f"  [cyan]◉[/cyan] [green]{ac['ssid']}[/green]"
            if ip: conn += f"  [dim]·  {ip}[/dim]"
        else:
            conn = "  [dim]○  not connected[/dim]"
        self.query_one("#header", Static).update(
            f"  [bold cyan]󰤨  wifimenu[/bold cyan]{conn}{hs_str}   [dim]{t}[/dim]   {flg}"
        )

    def _set_details(self, net):
        d = self.query_one("#details", Static)
        if net is None:
            d.update("\n  [dim]select a network[/dim]")
            return
        ac      = active_connection()
        is_conn = net.get("active") or (ac and ac.get("ssid") == net["ssid"])
        saved   = net["ssid"] in saved_networks()
        sig     = net["signal"]
        sec     = "WPA / WPA2" if net["security"] else "Open"
        lock    = "[cyan]󰌾[/cyan]" if net["security"] else "[dim]󰤮[/dim]"
        lines   = [
            "", f"  [bold cyan]{net['ssid']}[/bold cyan]", "",
            f"  [dim]Signal    [/dim] {sig_bar(sig)}  [cyan]{sig}%[/cyan]",
            f"  [dim]Security  [/dim] {lock}  {sec}",
        ]
        if is_conn and ac:
            ip_info = get_ip_info(ac.get("device", ""))
            if ip_info.get("ip"):
                lines.append(f"  [dim]IP        [/dim] [green]{ip_info['ip']}[/green]")
            if ip_info.get("gateway"):
                lines.append(f"  [dim]Gateway   [/dim] {ip_info['gateway']}")
            if ip_info.get("dns"):
                lines.append(f"  [dim]DNS       [/dim] {ip_info['dns']}")
            ping = self._ping
            if ping:
                lines.append(f"  [dim]Latency   [/dim] [cyan]{ping}[/cyan]")
        lines += ["", "  [dim]──────────────────[/dim]", ""]
        if is_conn:
            lines += [
                "  [green]◉  connected[/green]", "",
                "  [dim][D][/dim]  disconnect",
                "  [dim][C][/dim]  copy IP to clipboard",
                "  [dim][F][/dim]  forget network" if saved else "",
            ]
        else:
            if saved: lines.append("  [cyan]saved[/cyan]  [dim]— no password needed[/dim]")
            lines += [
                "",
                "  [dim][Enter][/dim]  connect",
                "  [dim][F][/dim]  forget" if saved else "",
            ]
        d.update("\n".join(l for l in lines))

    def _rebuild_list(self):
        lv = self.query_one("#network-list", ListView)
        lv.clear()
        self.query_one("#net-title", Label).update(
            f"  󰤨  NETWORKS ({len(self._networks)})")
        for net in self._networks:
            b    = bars(net["signal"])
            lock = "[cyan]󰌾[/cyan]" if net["security"] else "[dim]󰤮[/dim]"
            if net["active"]:
                row = f"  {b}  {lock}  [green]{net['ssid']}[/green]  [dim]{net['signal']}%[/dim]  [green]◉[/green]"
            else:
                row = f"  {b}  {lock}  {net['ssid']}  [dim]{net['signal']}%[/dim]"
            lv.append(ListItem(Label(row, markup=True)))

    def _status(self, msg):
        self.query_one("#statusbar", Static).update(f"  {msg}")

    # ── actions ──

    @work(thread=True)
    def action_scan(self):
        self.call_from_thread(self._status, "[yellow]⠿  scanning...[/yellow]")
        try:
            nets = scan_networks()
            self._networks = nets
            self.call_from_thread(self._rebuild_list)
            self.call_from_thread(self._refresh_header)
            self.call_from_thread(self._status,
                f"[green]✓  found {len(nets)} network{'s' if len(nets) != 1 else ''}[/green]")
        except Exception as e:
            self.call_from_thread(self._status, f"[red]✗  scan error: {e}[/red]")

    def action_connect(self):
        lv  = self.query_one("#network-list", ListView)
        idx = lv.index
        if idx is None or idx >= len(self._networks): return
        net = self._networks[idx]
        ac  = active_connection()
        if net["active"] or (ac and ac.get("ssid") == net["ssid"]):
            self._status("[yellow]already connected[/yellow]")
            return
        if net["security"]:
            self.push_screen(PasswordModal(net["ssid"]),
                             lambda pw: self._connect_cb(net["ssid"], pw))
        else:
            self._do_connect(net["ssid"], None)

    def _connect_cb(self, ssid, pw):
        if pw is None:
            self._status("[dim]cancelled[/dim]")
            return
        self._do_connect(ssid, pw)

    @work(thread=True)
    def _do_connect(self, ssid, password):
        self.call_from_thread(self._status, f"[yellow]connecting to {ssid}...[/yellow]")
        ok = do_connect(ssid, password)
        if ok:
            notify("Connected", f"Connected to {ssid}")
            ping = get_ping()
            self._ping = ping
            self.call_from_thread(self._status, f"[green]◉  connected to {ssid}[/green]")
            self.call_from_thread(self._refresh_header)
            time.sleep(0.5)
            nets = scan_networks()
            self._networks = nets
            self.call_from_thread(self._rebuild_list)
        else:
            self.call_from_thread(self._status, "[red]✗  failed — wrong password?[/red]")

    @work(thread=True)
    def action_disconnect(self):
        ok, ssid = do_disconnect()
        if not ok:
            self.call_from_thread(self._status, "[dim]not connected[/dim]")
            return
        notify("Disconnected", f"Disconnected from {ssid}", "low")
        self._ping = None
        self.call_from_thread(self._status, f"[dim]○  disconnected from {ssid}[/dim]")
        self.call_from_thread(self._refresh_header)

    @work(thread=True)
    def action_forget(self):
        lv  = self.query_one("#network-list", ListView)
        idx = lv.index
        if idx is None or idx >= len(self._networks): return
        net = self._networks[idx]
        if net["ssid"] not in saved_networks():
            self.call_from_thread(self._status, "[yellow]not a saved network[/yellow]")
            return
        do_forget(net["ssid"])
        self.call_from_thread(self._status, f"[dim]forgot {net['ssid']}[/dim]")

    def action_hotspot(self):
        active = hotspot_active()
        def handle(result):
            if result is None: return
            if result[0] == "stop":
                self._stop_hotspot(result[1])
            elif result[0] == "create":
                _, ssid, pw = result
                if not ssid:
                    self._status("[red]SSID cannot be empty[/red]")
                    return
                if len(pw) < 8:
                    self._status("[red]password must be 8+ characters[/red]")
                    return
                self._create_hotspot(ssid, pw)
        self.push_screen(HotspotModal(active), handle)

    @work(thread=True)
    def _create_hotspot(self, ssid, pw):
        self.call_from_thread(self._status, f"[yellow]creating hotspot '{ssid}'...[/yellow]")
        ok = create_hotspot(ssid, pw)
        if ok:
            notify("Hotspot Active", f"Hotspot '{ssid}' is running")
            self.call_from_thread(self._status, f"[green]󰤱  hotspot '{ssid}' active[/green]")
            self.call_from_thread(self._refresh_header)
        else:
            self.call_from_thread(self._status, "[red]✗  failed to create hotspot[/red]")

    @work(thread=True)
    def _stop_hotspot(self, name):
        stop_hotspot(name)
        self.call_from_thread(self._status, "[dim]hotspot stopped[/dim]")
        self.call_from_thread(self._refresh_header)

    def action_known(self):
        saved = saved_networks()
        if not saved:
            self._status("[dim]no saved networks[/dim]")
            return
        def handle(result):
            if result and result[0] == "forget":
                do_forget(result[1])
                self._status(f"[dim]forgot {result[1]}[/dim]")
        self.push_screen(KnownNetworksModal(saved), handle)

    @work(thread=True)
    def action_copy_ip(self):
        ac = active_connection()
        if not ac:
            self.call_from_thread(self._status, "[yellow]not connected[/yellow]")
            return
        ip_info = get_ip_info(ac.get("device", ""))
        ip = ip_info.get("ip")
        if not ip:
            self.call_from_thread(self._status, "[yellow]no IP found[/yellow]")
            return
        ok = copy_to_clipboard(ip)
        msg = f"[green]copied {ip} to clipboard[/green]" if ok else "[red]clipboard tool not found (install wl-copy)[/red]"
        self.call_from_thread(self._status, msg)

    @work(thread=True)
    def action_toggle(self):
        toggle_wifi()
        time.sleep(0.3)
        on    = wifi_enabled()
        color = "green" if on else "yellow"
        state = "enabled" if on else "disabled"
        self.call_from_thread(self._status, f"[{color}]wifi {state}[/{color}]")
        self.call_from_thread(self._refresh_header)

    @on(ListView.Selected)
    def on_net_selected(self, e): self.action_connect()

    @on(ListView.Highlighted)
    def on_net_highlighted(self, e):
        idx = e.list_view.index
        if idx is not None and idx < len(self._networks):
            net = self._networks[idx]
            self._set_details(net)
            # ping only when connected
            if net.get("active"):
                self._fetch_ping()
        else:
            self._set_details(None)

    @work(thread=True)
    def _fetch_ping(self):
        ping = get_ping()
        self._ping = ping
        lv  = self.query_one("#network-list", ListView)
        idx = lv.index
        if idx is not None and idx < len(self._networks):
            self.call_from_thread(self._set_details, self._networks[idx])

    def action_quit(self): self.exit()


if __name__ == "__main__":
    WifiApp().run()
