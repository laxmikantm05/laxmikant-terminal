    print("""wifimenu — cyberpunk WiFi manager

keybinds:
  [Enter]   connect to selected network
  [D]       disconnect from current network
  [F]       forget selected saved network
  [H]       hotspot — create or stop
  [K]       known networks — view/delete saved profiles
  [C]       copy current IP to clipboard
  [T]       toggle WiFi on/off
  [R]       force rescan now
  [Q]       quit

config: ~/.config/fancy-desktop/config.toml
""")
