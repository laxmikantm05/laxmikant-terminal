# ── config ───────────────────────────────────────────────────────

def load_config():
    cfg = {"wifi": {"scan_interval": 5, "header_interval": 2}}
    p   = pathlib.Path.home() / ".config" / "fancy-desktop" / "config.toml"
    if not p.exists():
        return cfg
    try:
        import tomllib
        with open(p, "rb") as f:
            data = tomllib.load(f)
        cfg["wifi"].update(data.get("wifi", {}))
    except Exception:
        pass
    return cfg

CFG = load_config()

# ── nmcli ────────────────────────────────────────────────────────

def run(cmd, timeout=12):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.stdout.strip(), r.returncode
    except Exception:
        return "", 1

def notify(title, body, urgency="normal"):
    try:
        subprocess.Popen(["notify-send", "-u", urgency, "-a", "wifimenu", title, body],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass

def copy_to_clipboard(text):
    for cmd in [["wl-copy"], ["xclip", "-selection", "clipboard"]]:
        try:
            subprocess.run(cmd, input=text, text=True,
                           capture_output=True, timeout=3)
            return True
        except Exception:
            continue
    return False

def wifi_enabled():
    out, _ = run(["nmcli", "radio", "wifi"])
    return out == "enabled"

def active_connection():
    out, _ = run(["nmcli", "-t", "-f", "ACTIVE,SSID,DEVICE", "dev", "wifi"])
    for line in out.splitlines():
        p = line.split(":")
        if len(p) >= 3 and p[0] == "yes":
            return {"ssid": p[1], "device": p[2]}
    return {}

def get_ip_info(device):
    if not device:
        return {}
    out, _ = run(["nmcli", "-t", "-f", "IP4.ADDRESS,IP4.GATEWAY,IP4.DNS", "dev", "show", device])
    info = {}
    for line in out.splitlines():
        if "IP4.ADDRESS" in line:
            info["ip"] = line.split(":")[-1].split("/")[0]
        elif "IP4.GATEWAY" in line:
            info["gateway"] = line.split(":")[-1]
        elif "IP4.DNS[1]" in line:
            info["dns"] = line.split(":")[-1]
    return info

def get_ping(host="8.8.8.8"):
    try:
        r = subprocess.run(["ping", "-c", "1", "-W", "1", host],
                           capture_output=True, text=True, timeout=3)
        for line in r.stdout.splitlines():
            if "time=" in line:
                ms = line.split("time=")[-1].split()[0]
                return f"{ms} ms"
    except Exception:
        pass
    return None

def scan_networks():
    run(["nmcli", "dev", "wifi", "rescan"])
    time.sleep(1.5)
    out, _ = run(["nmcli", "-t", "-f", "SSID,SIGNAL,SECURITY,ACTIVE", "dev", "wifi", "list"])
    seen = {}
    for line in out.splitlines():
        p = line.split(":")
        if len(p) < 4: continue
        ssid, signal, security, active = p[0], p[1], p[2], p[3]
        if not ssid.strip(): continue
        sig = int(signal) if signal.isdigit() else 0
        if ssid not in seen or sig > seen[ssid]["signal"]:
            seen[ssid] = {
                "ssid":     ssid.strip(),
                "signal":   sig,
                "security": security.strip() not in ("", "--"),
                "active":   active.strip() == "yes",
            }
    return sorted(seen.values(), key=lambda x: x["signal"], reverse=True)

def saved_networks():
    out, _ = run(["nmcli", "-t", "-f", "NAME,TYPE", "con", "show"])
    return [l.split(":")[0] for l in out.splitlines() if "wireless" in l]

def do_connect(ssid, password=None):
    if ssid in saved_networks():
        _, rc = run(["nmcli", "con", "up", ssid])
        return rc == 0
    if password:
        _, rc = run(["nmcli", "dev", "wifi", "connect", ssid, "password", password])
        return rc == 0
    _, rc = run(["nmcli", "dev", "wifi", "connect", ssid])
    return rc == 0

def do_disconnect():
    ac = active_connection()
    if not ac: return False, ""
    run(["nmcli", "dev", "disconnect", ac["device"]])
    return True, ac.get("ssid", "")

def do_forget(ssid):
    run(["nmcli", "con", "delete", ssid])

def toggle_wifi():
    run(["nmcli", "radio", "wifi", "off" if wifi_enabled() else "on"])

def hotspot_active():
    out, _ = run(["nmcli", "-t", "-f", "NAME,TYPE", "con", "show", "--active"])
    for line in out.splitlines():
        if "wireless" in line and ("Hotspot" in line or "hotspot" in line):
            return line.split(":")[0]
    return None

def create_hotspot(ssid, password):
    _, rc = run(["nmcli", "dev", "wifi", "hotspot", "ssid", ssid, "password", password])
    return rc == 0

def stop_hotspot(name):
    run(["nmcli", "con", "down", name])

# ── visual ────────────────────────────────────────────────────────

def bars(sig):
    if   sig >= 76: return "[cyan]▂▄▆█[/cyan]"
    elif sig >= 51: return "[cyan]▂▄▆[/cyan][dim]░[/dim]"
    elif sig >= 26: return "[cyan]▂▄[/cyan][dim]░░[/dim]"
    else:           return "[cyan]▂[/cyan][dim]░░░[/dim]"

def sig_bar(sig):
    filled = round(sig / 10)
    return "[cyan]" + "█" * filled + "[/cyan][dim]" + "░" * (10 - filled) + "[/dim]"

