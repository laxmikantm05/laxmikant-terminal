class PasswordModal(ModalScreen):
    CSS = MODAL_CSS
    def __init__(self, ssid):
        super().__init__()
        self.ssid = ssid
    def compose(self):
        with Container(classes="modal-box"):
            yield Label("  connect to network", classes="modal-title")
            yield Label(f"  {self.ssid}", classes="modal-sub")
            yield Input(placeholder="  password...", password=True, id="pw")
            yield Label("  [Enter] confirm   [Esc] cancel", classes="modal-hint")
    def on_mount(self): self.query_one("#pw", Input).focus()
    @on(Input.Submitted)
    def submitted(self, e): self.dismiss(e.value or None)
    def on_key(self, e):
        if e.key == "escape": self.dismiss(None)

class HotspotModal(ModalScreen):
    CSS = MODAL_CSS
    def __init__(self, active_name=None):
        super().__init__()
        self.active_name = active_name
    def compose(self):
        with Container(classes="modal-box"):
            if self.active_name:
                yield Label("  hotspot is active", classes="modal-title")
                yield Label(f"  {self.active_name}", classes="modal-sub")
                with Horizontal(classes="btn-row"):
                    yield Button("  stop hotspot", id="btn-stop",   classes="btn-cancel")
                    yield Button("  cancel",        id="btn-cancel", classes="btn-ok")
            else:
                yield Label("  create hotspot", classes="modal-title")
                yield Input(placeholder="  SSID (name)...",     id="inp-ssid", value="MyHotspot")
                yield Input(placeholder="  password (8+ chars)...", id="inp-pass", password=True)
                yield Label("  [Enter] in password field to create   [Esc] cancel", classes="modal-hint")
                with Horizontal(classes="btn-row"):
                    yield Button("  create", id="btn-create", classes="btn-ok")
                    yield Button("  cancel", id="btn-cancel", classes="btn-cancel")
    def on_mount(self):
        try: self.query_one("#inp-ssid", Input).focus()
        except Exception: pass
    @on(Button.Pressed, "#btn-stop")
    def stop(self):   self.dismiss(("stop", self.active_name))
    @on(Button.Pressed, "#btn-create")
    def create(self):
        ssid = self.query_one("#inp-ssid", Input).value.strip()
        pw   = self.query_one("#inp-pass", Input).value.strip()
        self.dismiss(("create", ssid, pw))
    @on(Button.Pressed, "#btn-cancel")
    def cancel(self): self.dismiss(None)
    def on_key(self, e):
        if e.key == "escape": self.dismiss(None)

class KnownNetworksModal(ModalScreen):
    CSS = MODAL_CSS + """
    ListView { height: 12; background: #0d0d1a; border: solid #1a1a3a; margin-bottom: 1; }
    ListItem { height: 2; background: #0d0d1a; border-bottom: solid #0f0f1f; }
    ListView:focus > ListItem.--highlight { background: #005f7f; border-left: tall #00eeff; }
    """
    def __init__(self, saved):
        super().__init__()
        self.saved = saved
    def compose(self):
        with Container(classes="modal-box"):
            yield Label(f"  saved networks ({len(self.saved)})", classes="modal-title")
            lv = ListView(id="known-list")
            yield lv
            yield Label("  [Enter] forget   [Esc] close", classes="modal-hint")
    def on_mount(self):
        lv = self.query_one("#known-list", ListView)
        for s in self.saved:
            lv.append(ListItem(Label(f"  󰤨  {s}", markup=True)))
        lv.focus()
    @on(ListView.Selected)
    def selected(self, e):
        idx = e.list_view.index
        if idx is not None and idx < len(self.saved):
            self.dismiss(("forget", self.saved[idx]))
    def on_key(self, e):
        if e.key == "escape": self.dismiss(None)

